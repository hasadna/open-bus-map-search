{
  "name": "open-bus-map-search",
  "version": "1.4.0",
  "private": true,
  "type": "module",
  "dependencies": {
    "@ant-design/icons": "^6.1.0",
    "@emotion/cache": "^11.14.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@hasadna/open-bus-api-client": "^1.2.3",
    "@juggle/resize-observer": "^3.4.0",
    "@mui/icons-material": "^7.3.9",
    "@mui/material": "^7.3.9",
    "@mui/x-date-pickers": "^8.27.2",
    "@mui/x-tree-view": "^8.27.2",
    "@rolldown/plugin-babel": "^0.2.2",
    "@tanstack/query-async-storage-persister": "^5.90.24",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-query-persist-client": "^5.95.0",
    "antd": "^6.3.3",
    "axios": "^1.13.6",
    "babel-plugin-react-compiler": "^1.0.0",
    "classnames": "^2.5.1",
    "dayjs": "^1.11.20",
    "es-toolkit": "^1.45.1",
    "geolib": "^3.3.4",
    "git-username": "^1.0.0",
    "http-proxy-middleware": "^3.0.5",
    "i18next": "^25.8.18",
    "i18next-fs-backend": "^2.6.1",
    "leaflet": "^1.9.4",
    "leaflet.markercluster": "^1.5.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-ga4": "^2.1.0",
    "react-i18next": "^16.6.2",
    "react-leaflet": "^5.0.0",
    "react-leaflet-markercluster": "^5.0.0-rc.0",
    "react-router": "^7.13.1",
    "recharts": "^3.8.0",
    "styled-components": "^6.3.11",
    "stylis-plugin-rtl": "^2.1.1",
    "use-konami": "^1.0.1",
    "usehooks-ts": "^3.1.1"
  },
  "resolutions": {
    "autoprefixer": "10.4.5"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "start": "vite",
    "build": "nx exec -- npm run _build && node sitemap.js",
    "serve": "vite preview",
    "test": "jest && playwright test --grep-invert visual",
    "test:e2e:ui": "cross-env APPLITOOLS_BATCH_ID=`uuidgen` playwright test --ui",
    "test:e2e": "cross-env APPLITOOLS_BATCH_ID=`uuidgen` playwright test",
    "test:e2e:visual": "playwright test tests/visual.spec.ts",
    "test:unit": "jest",
    "test:unit:ci": "jest --coverage",
    "lint": "tsc --noEmit && eslint --max-warnings 0 && stylelint '**/*.{css,scss}' --max-warnings 0 && prettier . -c -u",
    "lint:fix": "eslint --fix && stylelint '**/*.{css,scss}' --fix && prettier . -w -u",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "nx exec -- storybook build",
    "_build": "tsc && vite build",
    "test:storybook": "eyes-storybook",
    "test:offline": "bash scripts/test-offline.sh"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@applitools/eyes-playwright": "^1.46.2",
    "@applitools/eyes-storybook": "^3.64.8",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@nx/eslint": "22.5.4",
    "@nx/eslint-plugin": "22.6.3",
    "@playwright/test": "^1.58.2",
    "@storybook/addon-docs": "^10.3.2",
    "@storybook/react-vite": "^10.2.19",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/git-username": "^1.0.5",
    "@types/jest": "^30.0.0",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitejs/plugin-react": "^6.0.1",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-storybook": "^10.2.19",
    "globals": "^17.4.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "jsdom": "^29.0.0",
    "lightningcss": "^1.32.0",
    "msw": "^2.12.13",
    "msw-storybook-addon": "^2.0.6",
    "nx": "22.5.4",
    "playwright-advanced-har": "^1.4.1",
    "playwright-assertions": "^1.0.1",
    "prettier": "^3.8.1",
    "sass": "^1.98.0",
    "storybook": "^10.2.19",
    "stylelint": "^17.6.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-prettier": "^5.0.3",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3",
    "vite": "^8.0.0",
    "vite-plugin-istanbul": "^8.0.0"
  },
  "nx": {
    "targets": {
      "build": {
        "outputs": [
          "{projectRoot}/dist"
        ]
      },
      "build-storybook": {
        "outputs": [
          "{projectRoot}/storybook-static"
        ]
      }
    }
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
