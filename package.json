{
  "name": "open-bus-map-search",
  "version": "1.5.0",
  "private": true,
  "type": "module",
  "dependencies": {
    "@emotion/cache": "^11.14.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@hasadna/open-bus-api-client": "^1.2.3",
    "@juggle/resize-observer": "^3.4.0",
    "@mui/icons-material": "^9.1.1",
    "@mui/material": "^9.1.0",
    "@mui/stylis-plugin-rtl": "^9.0.1",
    "@mui/x-date-pickers": "^9.5.0",
    "@mui/x-tree-view": "^9.0.1",
    "@rolldown/plugin-babel": "^0.2.3",
    "@tanstack/query-async-storage-persister": "^5.96.2",
    "@tanstack/react-form": "^1.33.1",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-query-persist-client": "^5.101.2",
    "antd": "^6.3.3",
    "babel-plugin-react-compiler": "^1.0.0",
    "classnames": "^2.5.1",
    "dayjs": "^1.11.20",
    "es-toolkit": "^1.46.0",
    "geolib": "^3.3.4",
    "i18next": "^26.3.6",
    "i18next-fs-backend": "^2.6.5",
    "leaflet": "^1.9.4",
    "leaflet.markercluster": "^1.5.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-ga4": "^3.0.1",
    "react-i18next": "^16.6.2",
    "react-leaflet": "^5.0.0",
    "react-leaflet-markercluster": "^5.0.0-rc.0",
    "react-router": "^7.13.1",
    "recharts": "^3.8.0",
    "styled-components": "^6.3.11",
    "stylis": "^4.4.0",
    "use-konami": "^1.0.1",
    "usehooks-ts": "^3.1.1"
  },
  "resolutions": {
    "autoprefixer": "10.4.5"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "start": "vite",
    "build": "nx exec -- npm run _build && node sitemap.js",
    "serve": "vite preview",
    "test": "jest && playwright test --grep-invert visual",
    "test:e2e:ui": "cross-env APPLITOOLS_BATCH_ID=`uuidgen` playwright test --ui",
    "test:e2e": "cross-env APPLITOOLS_BATCH_ID=`uuidgen` playwright test",
    "test:e2e:visual": "playwright test tests/visual.spec.ts",
    "test:unit": "jest",
    "test:unit:ci": "jest --coverage",
    "lint": "tsc --noEmit && eslint --max-warnings 0 && stylelint '**/*.{css,scss}' --max-warnings 0 && prettier . -c -u",
    "lint:fix": "eslint --fix && stylelint '**/*.{css,scss}' --fix && prettier . -w -u",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "nx exec -- storybook build",
    "_build": "tsc && vite build",
    "test:storybook": "eyes-storybook",
    "test:offline": "bash scripts/test-offline.sh"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@applitools/eyes-playwright": "^1.47.9",
    "@applitools/eyes-storybook": "^3.67.1",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@nx/eslint-plugin": "^23.1.0",
    "@playwright/test": "^1.59.1",
    "@storybook/addon-docs": "^10.4.1",
    "@storybook/react-vite": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/jest": "^30.0.0",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/stylis": "^4.2.7",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.61.1",
    "@vitejs/plugin-react": "^6.0.2",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-i18next": "^6.1.5",
    "eslint-plugin-playwright": "^2.10.5",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-storybook": "^10.5.0",
    "globals": "^17.7.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "lightningcss": "^1.32.0",
    "msw": "^2.12.13",
    "msw-storybook-addon": "^2.0.7",
    "nx": "^23.0.0",
    "playwright-advanced-har": "^1.4.1",
    "playwright-assertions": "^1.0.1",
    "prettier": "^3.8.1",
    "sass": "^1.98.0",
    "storybook": "^10.4.1",
    "stylelint": "^17.13.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-prettier": "^5.0.3",
    "ts-jest": "^29.4.6",
    "typescript": "^6.0.3",
    "vite": "^8.0.10"
  },
  "nx": {
    "targets": {
      "build": {
        "outputs": [
          "{projectRoot}/dist"
        ]
      },
      "build-storybook": {
        "outputs": [
          "{projectRoot}/storybook-static"
        ]
      }
    }
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
