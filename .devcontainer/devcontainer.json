{
  "name": "Open Bus Dev container",
  "image": "mcr.microsoft.com/devcontainers/typescript-node:4-24-trixie",
  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/anthropics/devcontainer-features/claude-code:1.0": {}
  },
  "mounts": ["source=claude-code-config-${devcontainerId},target=/home/node/.claude,type=volume"],
  "forwardPorts": [3000, 6006],
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "stylelint.vscode-stylelint",
        "GitHub.vscode-github-actions",
        "ms-playwright.playwright"
      ]
    }
  },
  "postCreateCommand": "sudo chown -R node:node /home/node/.claude && npm install"
}
